VITE_BASE=/

# 接口地址 - Timer-Plus 生产环境 server
VITE_GLOB_API_URL=http://47.120.68.44:666

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式 - Electron 使用 hash 模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=false
